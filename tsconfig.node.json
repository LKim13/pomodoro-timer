{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./out/main",
    "rootDir": "./src/main"
  },
  "include": ["src/main/**", "src/preload/**", "src/shared/**"]
}